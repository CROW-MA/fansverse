# FANVERSE - Variables de Entorno (EJEMPLO)
# Copiar a .env y completar con valores reales

# Base de Datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fanverse_db
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña_segura

# JWT (generar con: openssl rand -base64 64)
JWT_SECRET=genera_un_valor_aleatorio_de_64_caracteres
JWT_REFRESH_SECRET=genera_otro_valor_aleatorio_de_64_caracteres

# Stripe - Obtener en https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=clave_secreta_stripe
STRIPE_PUBLIC_KEY=clave_publica_stripe
STRIPE_WEBHOOK_SECRET=clave_webhook_stripe

# Email SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=clave_app_16_digitos

# URLs
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
